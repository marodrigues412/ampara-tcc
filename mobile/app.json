{
  "expo": {
    "name": "Ampara",
    "slug": "ampara-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png", 
    "scheme": "mobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#F5F3EF",
        "foregroundImage": "./assets/images/icon.png"
      },
      "edgeToEdgeEnabled": true
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 250,
          "resizeMode": "contain",
          "backgroundColor": "#F5F3EF" 
        }
      ]
    ]
  }
}